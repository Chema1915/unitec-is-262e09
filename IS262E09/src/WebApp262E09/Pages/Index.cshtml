@page
@model IndexModel
@{
    ViewData["Title"] = "Calculadora";
}

<div class="text-center">
    <h1>Calculadora de Áreas</h1>
    
    <form method="post" style="margin-top: 20px;">
        <label>Ingrese el lado:</label>
        <input type="number" id="input-lado" asp-for="Lado" required />
        <button type="submit" id="btn-calcular">Calcular</button>
    </form>

    @if (Model.AreaResultado.HasValue)
    {
        <h3 style="margin-top: 20px;">
            El área es: <span id="resultado">@Model.AreaResultado</span>
        </h3>
    }
</div>