@page
@{
    double lado = 5.0; 
    double perimetro = 3 * lado;  
    double area = (Math.Sqrt(3) / 4) *  Math.Pow(lado, 2); 
    double areaRedondeada = Math.Round(area, 2); 
}
<body style="background-color:gray;">
</br>
<h1 style="text-align:center;color:white;">El Perimetro de un triangulo de @(lado)cm de lado es: @(perimetro)cm</h1>
</br>
<h1 style="text-align:center;color:white;">El Area de un triangulo de @(lado)cm de lado es: @(areaRedondeada)cm²</h1>
</body>